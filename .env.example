# ===========================================
# SALDOPEDIA ENVIRONMENT VARIABLES
# ===========================================

# -------------------------------------------
# DATABASE (gunakan APP_DATABASE_URL, bukan DATABASE_URL)
# -------------------------------------------
APP_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# -------------------------------------------
# DOMAIN & APP
# -------------------------------------------
CUSTOM_DOMAIN=saldopedia.com
NEXT_PUBLIC_APP_URL=https://saldopedia.com

# -------------------------------------------
# SECURITY SECRETS
# -------------------------------------------
JWT_SECRET=your-jwt-secret-key-min-32-chars
ORDER_COMPLETION_SECRET=your-order-completion-secret
CRON_SECRET=your-cron-secret-for-scheduled-jobs

# -------------------------------------------
# RECAPTCHA (Google reCAPTCHA v2)
# -------------------------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# -------------------------------------------
# GOOGLE VERIFICATION
# -------------------------------------------
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-site-verification-code

# -------------------------------------------
# EMAIL (Brevo/Sendinblue)
# -------------------------------------------
BREVO_API_KEY=your-brevo-api-key
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# -------------------------------------------
# ADMIN ACCOUNTS (PayPal & Skrill)
# -------------------------------------------
ADMIN_PAYPAL_EMAIL=admin-paypal@example.com
ADMIN_SKRILL_EMAIL=admin-skrill@example.com

# -------------------------------------------
# NOWPAYMENTS (Crypto Automation)
# -------------------------------------------
# Phase 1: SELL (auto-credit saldo)
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret

# Phase 2: BUY (auto-payout crypto)
NOWPAYMENTS_EMAIL=your-nowpayments-login-email
NOWPAYMENTS_PASSWORD=your-nowpayments-login-password
NOWPAYMENTS_TOTP_SECRET=your-totp-secret-from-authenticator-app
